#!/usr/bin/env bash
set -euo pipefail

# AI Development Toolkit Installer
# Installs prompts, skills, and workflows into a target repo's .github/ directory.

REPO_URL="https://github.com/marcoacciarri/ai"
RAW_BASE="https://raw.githubusercontent.com/marcoacciarri/ai/main"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
  cat <<EOF
${BOLD}AI Development Toolkit Installer${NC}

Usage: ./install-agents [OPTIONS] [COMPONENTS...]

Components (default: all):
  skills       Install agent skills (17 skills)
  prompts      Install prompt files (/build, /prd-create)
  workflow     Install mobile trigger workflow (/agent commands)

Options:
  --force      Overwrite existing files without prompting
  --dry-run    Show what would be installed without writing files
  --help       Show this help message

Examples:
  ./install-agents                  # Install everything
  ./install-agents skills prompts   # Install skills and prompts only
  ./install-agents --force          # Overwrite all existing files
  ./install-agents --dry-run        # Preview changes
EOF
}

# --- State ---
FORCE=false
DRY_RUN=false
COMPONENTS=()
INSTALLED=0
SKIPPED=0
CONFLICTS=0

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)  FORCE=true; shift ;;
    --dry-run) DRY_RUN=true; shift ;;
    --help|-h) usage; exit 0 ;;
    skills|prompts|workflow) COMPONENTS+=("$1"); shift ;;
    *) echo -e "${RED}Unknown argument: $1${NC}"; usage; exit 1 ;;
  esac
done

# Default to all components
if [[ ${#COMPONENTS[@]} -eq 0 ]]; then
  COMPONENTS=(skills prompts workflow)
fi

# --- Helpers ---
install_file() {
  local src="$1"
  local dest="$2"

  if [[ "$DRY_RUN" == true ]]; then
    if [[ -f "$dest" ]]; then
      echo -e "  ${YELLOW}would overwrite${NC} $dest"
    else
      echo -e "  ${GREEN}would create${NC} $dest"
    fi
    return
  fi

  if [[ -f "$dest" && "$FORCE" != true ]]; then
    CONFLICTS=$((CONFLICTS + 1))
    echo -e "  ${YELLOW}exists${NC} $dest (use --force to overwrite)"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  mkdir -p "$(dirname "$dest")"
  cp "$src" "$dest"
  INSTALLED=$((INSTALLED + 1))

  if [[ -f "$dest" ]]; then
    echo -e "  ${GREEN}✓${NC} $dest"
  fi
}

install_dir() {
  local src_dir="$1"
  local dest_dir="$2"

  if [[ ! -d "$src_dir" ]]; then
    echo -e "  ${RED}✗ Source not found: $src_dir${NC}"
    return 1
  fi

  find "$src_dir" -type f | while read -r file; do
    local rel="${file#"$src_dir"/}"
    install_file "$file" "$dest_dir/$rel"
  done
}

# --- Detect source ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -d "$SCRIPT_DIR/.github/skills" ]]; then
  SOURCE_DIR="$SCRIPT_DIR/.github"
elif [[ -d "./.github/skills" && "$(pwd)" == "$SCRIPT_DIR" ]]; then
  echo -e "${RED}Cannot install into the toolkit repo itself.${NC}"
  exit 1
else
  # Try to clone/download
  echo -e "${BLUE}Source not found locally. Attempting to download...${NC}"
  TMPDIR=$(mktemp -d)
  trap 'rm -rf "$TMPDIR"' EXIT

  if command -v git &>/dev/null; then
    git clone --depth 1 "$REPO_URL.git" "$TMPDIR/repo" 2>/dev/null || {
      echo -e "${RED}Failed to clone $REPO_URL${NC}"
      echo "Make sure the repository exists and is accessible."
      exit 1
    }
    SOURCE_DIR="$TMPDIR/repo/.github"
  else
    echo -e "${RED}git is required to download the toolkit.${NC}"
    echo "Install git or run this script from within the cloned toolkit repo."
    exit 1
  fi
fi

if [[ ! -d "$SOURCE_DIR" ]]; then
  echo -e "${RED}Source .github/ directory not found at $SOURCE_DIR${NC}"
  exit 1
fi

# --- Target directory ---
TARGET=".github"

echo ""
echo -e "${BOLD}AI Development Toolkit${NC}"
echo -e "Installing into ${BLUE}$(pwd)/$TARGET${NC}"
echo ""

# --- Install components ---
for component in "${COMPONENTS[@]}"; do
  case "$component" in
    skills)
      echo -e "${BOLD}Skills${NC} (18 skills)"
      install_dir "$SOURCE_DIR/skills" "$TARGET/skills"
      echo ""
      ;;
    prompts)
      echo -e "${BOLD}Prompts${NC}"
      install_dir "$SOURCE_DIR/prompts" "$TARGET/prompts"
      echo ""
      ;;
    workflow)
      echo -e "${BOLD}Workflow${NC}"
      install_file "$SOURCE_DIR/workflows/mobile-trigger.yml" "$TARGET/workflows/mobile-trigger.yml"
      echo ""
      ;;
  esac
done

# --- Summary ---
echo -e "${BOLD}─────────────────────────${NC}"
if [[ "$DRY_RUN" == true ]]; then
  echo -e "${BLUE}Dry run complete. No files were written.${NC}"
else
  echo -e "${GREEN}Installed: $INSTALLED files${NC}"
  if [[ $SKIPPED -gt 0 ]]; then
    echo -e "${YELLOW}Skipped: $SKIPPED files (already exist)${NC}"
  fi
  if [[ $CONFLICTS -gt 0 ]]; then
    echo ""
    echo -e "Run with ${BOLD}--force${NC} to overwrite existing files."
  fi
fi
echo ""
